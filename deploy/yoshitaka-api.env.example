# /etc/yoshitaka-api.env — copy to /etc/yoshitaka-api.env (chmod 600)
# All values are required unless explicitly marked optional.

# MySQL on the same VPS (aiomysql wants TCP, so use 127.0.0.1 not a unix socket)
DATABASE_URL=mysql+aiomysql://yoshi_app:REPLACE_WITH_STRONG_PASS@127.0.0.1:3306/yoshitaka

# 32+ random characters. Generate with:  openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32

# Comma-separated allow-list of front-end origins. Frontend and API share the
# same origin (path-based routing), so just one entry is needed.
CORS_ORIGINS=https://portal.yoshitakakaratedo.com

# Optional — leave blank on a VPS, the backend is always warm.
KEEP_WARM_URL=

# Optional — set to 1 only if you ever point DATABASE_URL at a remote
# MySQL with aggressive idle-drop. Local-socket MySQL doesn't need this.
DB_USE_NULLPOOL=0
